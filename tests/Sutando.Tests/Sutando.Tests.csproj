<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <!-- MEAI001 and SUTANDO001 mark experimental local-inference surfaces. Tests need to
         consume them without per-usage [SuppressMessage] attributes. -->
    <NoWarn>$(NoWarn);MEAI001;SUTANDO001</NoWarn>
  </PropertyGroup>

  <!-- Multi-target on Windows so the Windows-only platform adapter (and its tests) compile against a
       Windows TFM, while cross-platform tests stay on net10.0. On non-Windows hosts we collapse to a
       single net10.0 target so the test assembly continues to restore + build everywhere.
       NOTE: Directory.Build.props sets a default <TargetFramework>; we clear it so the conditional
       <TargetFrameworks> below can take effect on Windows. -->
  <PropertyGroup>
    <TargetFramework></TargetFramework>
  </PropertyGroup>
  <PropertyGroup Condition="'$(OS)' != 'Windows_NT'">
    <TargetFramework>net10.0</TargetFramework>
  </PropertyGroup>
  <PropertyGroup Condition="'$(OS)' == 'Windows_NT'">
    <TargetFrameworks>net10.0;net10.0-windows10.0.19041.0</TargetFrameworks>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.13.0" />
    <PackageReference Include="xunit" Version="2.9.3" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.0.1" />
    <PackageReference Include="xunit.SkippableFact" Version="1.4.13" />
    <PackageReference Include="coverlet.collector" Version="6.0.4" />
    <!-- Api / Dashboard / Voice tests stand their hosts up in-process via WebApplicationFactory.
         SignalR.Client is for Dashboard hub round-trip tests. -->
    <PackageReference Include="Microsoft.AspNetCore.Mvc.Testing" Version="10.0.0" />
    <PackageReference Include="Microsoft.AspNetCore.SignalR.Client" Version="10.0.0" />
    <!-- Aspire.Hosting.Testing exposes DistributedApplicationTestingBuilder, which we
         use in tests/AppHost/ to inspect the AppHost's resource graph without booting
         Docker. Version-pinned alongside Aspire.AppHost.Sdk in Sutando.AppHost.csproj. -->
    <PackageReference Include="Aspire.Hosting.Testing" Version="13.3.3" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Xunit" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Sutando.Workspace\Sutando.Workspace.csproj" />
    <ProjectReference Include="..\..\src\Sutando.Bridge\Sutando.Bridge.csproj" />
    <ProjectReference Include="..\..\src\Sutando.Core\Sutando.Core.csproj" />
    <ProjectReference Include="..\..\src\Sutando.Platform.Abstractions\Sutando.Platform.Abstractions.csproj" />
    <ProjectReference Include="..\..\src\Sutando.Browser\Sutando.Browser.csproj" />
    <ProjectReference Include="..\..\src\Sutando.Channels.Cli\Sutando.Channels.Cli.csproj" />
    <ProjectReference Include="..\..\src\Sutando.Channels.Telegram\Sutando.Channels.Telegram.csproj" />
    <ProjectReference Include="..\..\src\Sutando.Channels.Discord\Sutando.Channels.Discord.csproj" />
    <ProjectReference Include="..\..\src\Sutando.Realtime\Sutando.Realtime.csproj" />
    <ProjectReference Include="..\..\src\Sutando.Skills\Sutando.Skills.csproj" />
    <ProjectReference Include="..\..\src\Sutando.Skills.Cloud\Sutando.Skills.Cloud.csproj" />
    <ProjectReference Include="..\..\src\Sutando.Notes\Sutando.Notes.csproj" />
    <ProjectReference Include="..\..\src\Sutando.LocalInference.Abstractions\Sutando.LocalInference.Abstractions.csproj" />
    <ProjectReference Include="..\..\src\Sutando.LocalInference.WhisperNet\Sutando.LocalInference.WhisperNet.csproj" />
    <ProjectReference Include="..\..\src\Sutando.LocalInference.KokoroSharp\Sutando.LocalInference.KokoroSharp.csproj" />
    <ProjectReference Include="..\..\src\Sutando.LocalInference.LlamaSharp\Sutando.LocalInference.LlamaSharp.csproj" />
    <ProjectReference Include="..\..\src\Sutando.LocalInference.Silero\Sutando.LocalInference.Silero.csproj" />
    <ProjectReference Include="..\..\src\Sutando.LocalInference.OpenAI\Sutando.LocalInference.OpenAI.csproj" />
    <ProjectReference Include="..\..\src\Sutando.Pipeline\Sutando.Pipeline.csproj" />
    <ProjectReference Include="..\..\src\Sutando.Api\Sutando.Api.csproj" />
    <ProjectReference Include="..\..\src\Sutando.Dashboard\Sutando.Dashboard.csproj" />
    <ProjectReference Include="..\..\src\Sutando.Voice\Sutando.Voice.csproj" />
    <!-- Sutando.Voice.Local is the local-inference voice transport (phase #21). Pulled in
         transitively via Sutando.Voice, but referenced explicitly so the LocalPipeline tests
         can construct its types directly. Added to Sutando.sln by the integration phase. -->
    <ProjectReference Include="..\..\src\Sutando.Voice.Local\Sutando.Voice.Local.csproj" />
    <ProjectReference Include="..\..\src\Sutando.Phone\Sutando.Phone.csproj" />
    <!-- Sutando.AppHost is the Aspire 13 orchestrator. The tests in tests/AppHost/ reflect on
         its compiled entry-point via Aspire.Hosting.Testing, so a ProjectReference is required
         even though we never instantiate Sutando.AppHost types directly. -->
    <ProjectReference Include="..\..\src\Sutando.AppHost\Sutando.AppHost.csproj" />
  </ItemGroup>

  <!-- Windows-only project reference + test sources. Other TFMs simply don't see the files. -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net10.0-windows10.0.19041.0'">
    <ProjectReference Include="..\..\src\Sutando.Platform.Windows\Sutando.Platform.Windows.csproj" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' != 'net10.0-windows10.0.19041.0'">
    <Compile Remove="Platform\Windows\**\*.cs" />
  </ItemGroup>

</Project>
